PORT=3000
NODE_ENV=production
APP_URL=https://yourdomain.com
CLIENT_URL=https://yourdomain.com

DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_hostinger_database_name
DB_USER=your_hostinger_database_user
DB_PASSWORD=your_hostinger_database_password

JWT_ACCESS_SECRET=replace_with_a_long_random_access_secret
JWT_REFRESH_SECRET=replace_with_a_different_long_random_refresh_secret
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d

COOKIE_SECURE=true

AI_PROVIDER=gemini
OPENAI_API_KEY=
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
