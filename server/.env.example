PORT=3000
NODE_ENV=production
APP_URL=https://yourdomain.com
CLIENT_URL=https://yourdomain.com

JWT_ACCESS_SECRET=replace_with_a_long_random_access_secret
JWT_REFRESH_SECRET=replace_with_a_different_long_random_refresh_secret
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d

COOKIE_SECURE=true

AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
SQLITE_DB_PATH=server/data/app.sqlite

DEFAULT_ADMIN_EMAIL=admin@gsmportal.local
DEFAULT_ADMIN_PASSWORD=Admin@12345!
RESET_DEFAULT_ADMIN=false
